<view class="tabbar">
  <view class="tab-item {{current === 0 ? 'active' : ''}}" data-page="0" bindtap="switchTab">
    <text class="tab-icon">🏠</text>
    <text class="tab-text">首页</text>
  </view>
  <view class="tab-item {{current === 1 ? 'active' : ''}}" data-page="1" bindtap="switchTab">
    <text class="tab-icon">📖</text>
    <text class="tab-text">关于</text>
  </view>
  <view class="tab-item {{current === 2 ? 'active' : ''}}" data-page="2" bindtap="switchTab">
    <text class="tab-icon">📁</text>
    <text class="tab-text">案例</text>
  </view>
  <view class="tab-item {{current === 3 ? 'active' : ''}}" data-page="3" bindtap="switchTab">
    <text class="tab-icon">📞</text>
    <text class="tab-text">联系</text>
  </view>
</view>
