.tabbar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255, 255, 255, 0.98);
  backdrop-filter: blur(20rpx);
  display: flex;
  justify-content: space-around;
  padding: 10rpx 0 calc(10rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
  z-index: 1000;
}

.tab-item {
  text-align: center;
  color: #999999;
  font-size: 10rpx;
  padding: 5rpx 15rpx;
  transition: all 0.3s ease;
  position: relative;
}

.tab-item.active {
  color: #1a1a1a;
}

.tab-icon {
  display: block;
  font-size: 22rpx;
  margin-bottom: 5rpx;
  transition: transform 0.3s ease;
}

.tab-item.active .tab-icon {
  transform: translateY(-3rpx);
}

.tab-text {
  display: block;
}

.tab-item::before {
  content: '';
  position: absolute;
  top: -10rpx;
  left: 50%;
  transform: translateX(-50%) scaleX(0);
  width: 40rpx;
  height: 3rpx;
  background: #c9a962;
  border-radius: 0 0 3rpx 3rpx;
  transition: transform 0.3s ease;
}

.tab-item.active::before {
  transform: translateX(-50%) scaleX(1);
}
