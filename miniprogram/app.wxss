/* app.wxss - 全局样式 */

page {
  --primary: #1a1a1a;
  --secondary: #666666;
  --accent: #c9a962;
  --bg: #f8f8f8;
  --white: #ffffff;
  --text-light: #999999;

  background-color: var(--bg);
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  color: var(--primary);
  line-height: 1.6;
}

/* 通用类 */
.container {
  box-sizing: border-box;
}

/* 渐变背景 */
.gradient-gold {
  background: linear-gradient(135deg, #1a1a1a, #c9a962);
}

/* 阴影 */
.shadow {
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

/* 圆角 */
.rounded {
  border-radius: 16rpx;
}

/*  flex 居中 */
.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}
