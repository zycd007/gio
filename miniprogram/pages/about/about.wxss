page {
  background: #f8f8f8;
}

.container {
  padding-bottom: 20rpx;
}

.about-hero {
  background: linear-gradient(135deg, #1a1a1a, #333333);
  padding: 100rpx 30rpx 80rpx;
  text-align: center;
}

.about-title {
  display: block;
  font-size: 32rpx;
  font-weight: 300;
  letter-spacing: 6rpx;
  color: #ffffff;
  margin-bottom: 15rpx;
}

.about-subtitle {
  display: block;
  font-size: 13rpx;
  color: rgba(255, 255, 255, 0.7);
  letter-spacing: 2rpx;
}

.about-content {
  background: #ffffff;
  margin: 20rpx;
  padding: 40rpx 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.about-section-title {
  display: block;
  font-size: 18rpx;
  font-weight: 500;
  text-align: center;
  margin-bottom: 25rpx;
  color: #1a1a1a;
}

.about-text {
  display: block;
  font-size: 15rpx;
  color: #666666;
  line-height: 2.2;
  margin-bottom: 20rpx;
  text-align: justify;
}

.highlights {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 15rpx;
  margin-top: 30rpx;
}

.highlight-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 10rpx;
}

.highlight-icon {
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(135deg, #1a1a1a, #c9a962);
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  margin-right: 15rpx;
  flex-shrink: 0;
}

.highlight-text {
  font-size: 13rpx;
  color: #666666;
}

.stats {
  display: flex;
  justify-content: space-around;
  padding: 50rpx 30rpx;
  background: #ffffff;
  margin: 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.stat-item {
  text-align: center;
  padding: 20rpx;
}

.stat-num {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #1a1a1a, #c9a962);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 10rpx;
}

.stat-label {
  display: block;
  font-size: 12rpx;
  color: #999999;
  letter-spacing: 2rpx;
}
