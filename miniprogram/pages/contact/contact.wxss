page {
  background: #f8f8f8;
}

.container {
  padding-bottom: 20rpx;
}

.contact-hero {
  background: linear-gradient(135deg, #1a1a1a, #2a2a2a);
  padding: 80rpx 30rpx 60rpx;
  text-align: center;
}

.contact-title {
  display: block;
  font-size: 28rpx;
  font-weight: 300;
  letter-spacing: 4rpx;
  color: #ffffff;
  margin-bottom: 10rpx;
}

.contact-subtitle {
  display: block;
  font-size: 13rpx;
  color: rgba(255, 255, 255, 0.7);
}

.contact-section {
  padding: 30rpx;
}

.contact-card {
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
}

.contact-item {
  display: flex;
  align-items: center;
  padding: 25rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.contact-item:last-child {
  border-bottom: none;
}

.contact-icon {
  width: 50rpx;
  height: 50rpx;
  background: linear-gradient(135deg, #1a1a1a, #c9a962);
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.contact-text {
  flex: 1;
}

.contact-label {
  display: block;
  font-size: 11rpx;
  color: #999999;
  text-transform: uppercase;
  letter-spacing: 1rpx;
  margin-bottom: 5rpx;
}

.contact-value {
  display: block;
  font-size: 15rpx;
  color: #1a1a1a;
  font-weight: 500;
}

.qr-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  margin-top: 20rpx;
}

.qr-title {
  display: block;
  font-size: 16rpx;
  font-weight: 500;
  color: #1a1a1a;
  margin-bottom: 10rpx;
}

.qr-desc {
  display: block;
  font-size: 13rpx;
  color: #999999;
  margin-bottom: 25rpx;
}

.qr-code {
  width: 200rpx;
  height: 200rpx;
  background: linear-gradient(135deg, #1a1a1a, #333333);
  margin: 0 auto 20rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.qr-placeholder {
  font-size: 60rpx;
}

.qr-hint {
  display: block;
  font-size: 12rpx;
  color: #999999;
}

.contact-form {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  margin-top: 20rpx;
}

.form-title {
  display: block;
  font-size: 16rpx;
  font-weight: 500;
  text-align: center;
  margin-bottom: 25rpx;
  color: #1a1a1a;
}

.form-group {
  margin-bottom: 20rpx;
}

.form-input {
  width: 100%;
  height: 50rpx;
  padding: 15rpx 20rpx;
  background: #f8f8f8;
  border-radius: 10rpx;
  font-size: 14rpx;
  border: 1rpx solid transparent;
}

.form-input:focus {
  background: #ffffff;
  border-color: #c9a962;
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  padding: 15rpx 20rpx;
  background: #f8f8f8;
  border-radius: 10rpx;
  font-size: 14rpx;
  border: 1rpx solid transparent;
}

.form-textarea:focus {
  background: #ffffff;
  border-color: #c9a962;
}

.input-placeholder {
  color: #999999;
}

.form-submit {
  width: 100%;
  height: 50rpx;
  background: linear-gradient(135deg, #1a1a1a, #333333);
  color: #ffffff;
  border: none;
  border-radius: 12rpx;
  font-size: 15rpx;
  font-weight: 500;
  margin-top: 10rpx;
}
