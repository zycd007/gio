<view class="container">
  <view class="project-hero">
    <view class="project-img-placeholder">
      <image wx:if="{{project.images && project.images.length > 0}}" src="{{project.images[0]}}" mode="aspectFill" class="project-cover-img" />
      <text wx:else class="project-name-large">{{project.name}}</text>
    </view>
  </view>

  <view class="project-content">
    <view class="project-header">
      <text class="project-title">{{project.name}}</text>
      <view class="project-tags">
        <text class="tag">{{project.type}}</text>
        <text class="tag">{{project.year}}</text>
      </view>
    </view>

    <view class="project-info-section">
      <view class="info-item">
        <text class="info-label">项目位置</text>
        <text class="info-value">📍 {{project.location}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">完成时间</text>
        <text class="info-value">{{project.year}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">项目类型</text>
        <text class="info-value">{{project.type}}</text>
      </view>
    </view>

    <view class="project-description">
      <text class="desc-title">项目介绍</text>
      <text class="desc-text">
        这是一个由 GIO&SJ 设计团队精心打造的{{project.type}}项目。
        我们秉承"氛围营造情绪底色"的设计理念，从概念到落地全程把控，
        确保设计初衷完美呈现。每个细节都经过精心打磨，力求为客户创造
        独特的空间体验。
      </text>
    </view>

    <view class="project-gallery" wx:if="{{project.images && project.images.length > 0}}">
      <text class="gallery-title">项目图片</text>
      <view class="gallery-grid">
        <view class="gallery-item" wx:for="{{project.images}}" wx:key="*this" bindtap="previewImage" data-index="{{index}}">
          <image src="{{item}}" mode="aspectFill" class="gallery-img" />
        </view>
      </view>
    </view>

    <view class="project-gallery" wx:else>
      <text class="gallery-title">项目图片</text>
      <view class="gallery-grid">
        <view class="gallery-item" wx:for="{{[1,2,3,4]}}" wx:key="*this">
          <view class="gallery-placeholder">
            <text>图片 {{item}}</text>
          </view>
        </view>
      </view>
    </view>

    <button class="contact-btn" bindtap="contactUs">咨询该项目</button>
  </view>
</view>
