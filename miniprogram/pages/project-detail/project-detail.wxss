page {
  background: #f8f8f8;
}

.container {
  min-height: 100vh;
  padding-bottom: 30rpx;
}

.project-hero {
  background: #ffffff;
  padding-bottom: 30rpx;
}

.project-img-placeholder {
  height: 400rpx;
  background: linear-gradient(135deg, #1a1a1a, #3a3a3a);
  display: flex;
  align-items: center;
  justify-content: center;
}

.project-name-large {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 500;
  letter-spacing: 2rpx;
}

.project-content {
  padding: 30rpx;
}

.project-header {
  background: #ffffff;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.project-title {
  display: block;
  font-size: 22rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 20rpx;
}

.project-tags {
  display: flex;
  gap: 15rpx;
}

.tag {
  padding: 8rpx 16rpx;
  background: #f8f8f8;
  border-radius: 20rpx;
  font-size: 12rpx;
  color: #666666;
}

.project-info-section {
  background: #ffffff;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 14rpx;
  color: #999999;
}

.info-value {
  font-size: 14rpx;
  color: #1a1a1a;
  font-weight: 500;
}

.project-description {
  background: #ffffff;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.desc-title {
  display: block;
  font-size: 16rpx;
  font-weight: 500;
  color: #1a1a1a;
  margin-bottom: 20rpx;
}

.desc-text {
  display: block;
  font-size: 14rpx;
  color: #666666;
  line-height: 2;
  text-align: justify;
}

.project-gallery {
  background: #ffffff;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.gallery-title {
  display: block;
  font-size: 16rpx;
  font-weight: 500;
  color: #1a1a1a;
  margin-bottom: 20rpx;
}

.gallery-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 15rpx;
}

.gallery-item {
  border-radius: 12rpx;
  overflow: hidden;
}

.gallery-placeholder {
  height: 200rpx;
  background: linear-gradient(135deg, #2a2a2a, #3a3a3a);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 14rpx;
}

.contact-btn {
  width: 100%;
  height: 50rpx;
  background: linear-gradient(135deg, #1a1a1a, #333333);
  color: #ffffff;
  border: none;
  border-radius: 12rpx;
  font-size: 15rpx;
  font-weight: 500;
  margin-top: 20rpx;
}
