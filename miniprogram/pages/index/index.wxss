page {
  background: #f8f8f8;
}

.container {
  padding-bottom: 20rpx;
}

/* Hero Section */
.hero {
  background: linear-gradient(135deg, #0a0a0a 0%, #1a1a1a 50%, #2a2a2a 100%);
  padding: 120rpx 30rpx 80rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.hero::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: url('data:image/svg+xml;base64,');
  opacity: 0.5;
}

.hero-content {
  position: relative;
  z-index: 1;
}

.hero-title {
  display: block;
  font-size: 48rpx;
  font-weight: 300;
  letter-spacing: 12rpx;
  color: #ffffff;
  margin-bottom: 20rpx;
}

.hero-subtitle {
  display: block;
  font-size: 12rpx;
  color: rgba(255, 255, 255, 0.5);
  letter-spacing: 3rpx;
  text-transform: uppercase;
  margin-bottom: 40rpx;
}

.hero-since {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  padding: 10rpx 30rpx;
  font-size: 11rpx;
  letter-spacing: 3rpx;
  border-radius: 30rpx;
}

/* Tagline */
.tagline {
  background: #ffffff;
  padding: 60rpx 30rpx;
  text-align: center;
}

.tagline-icon {
  display: block;
  font-size: 30rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.tagline-text {
  display: block;
  font-size: 15rpx;
  color: #666666;
  line-height: 2.2;
  margin-bottom: 10rpx;
}

/* Section */
.section {
  background: #ffffff;
  margin-top: 10rpx;
  padding: 60rpx 30rpx;
}

.section.services {
  background: linear-gradient(180deg, #f8f8f8 0%, #ffffff 100%);
}

.section.cities {
  background: #1a1a1a;
}

.section-header {
  text-align: center;
  margin-bottom: 50rpx;
}

.section-label {
  display: block;
  font-size: 11rpx;
  color: #c9a962;
  letter-spacing: 3rpx;
  text-transform: uppercase;
  margin-bottom: 15rpx;
}

.section-title {
  display: block;
  font-size: 24rpx;
  font-weight: 400;
  letter-spacing: 4rpx;
  color: #1a1a1a;
}

.cities .section-title {
  color: #ffffff;
}

/* Core Grid */
.core-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 15rpx;
  max-width: 600rpx;
  margin: 0 auto;
}

.core-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 30rpx 20rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
}

.core-icon {
  font-size: 32rpx;
  margin-bottom: 15rpx;
}

.core-name {
  font-size: 14rpx;
  color: #1a1a1a;
  font-weight: 500;
}

/* Service List */
.service-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 15rpx;
}

.service-item {
  display: flex;
  align-items: center;
  background: #ffffff;
  padding: 15rpx 25rpx;
  border-radius: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.service-dot {
  width: 6rpx;
  height: 6rpx;
  background: #c9a962;
  border-radius: 50%;
  margin-right: 10rpx;
}

.service-name {
  font-size: 14rpx;
  color: #666666;
}

/* City Grid */
.city-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 20rpx;
  max-width: 600rpx;
  margin: 0 auto;
}

.city-item {
  text-align: center;
  padding: 20rpx 10rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 8rpx;
  font-size: 14rpx;
  color: #ffffff;
}

/* Stats */
.stats {
  display: flex;
  justify-content: space-around;
  padding: 50rpx 30rpx;
  background: #ffffff;
  margin-top: 10rpx;
}

.stat-item {
  text-align: center;
  padding: 20rpx;
}

.stat-num {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #1a1a1a, #c9a962);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 10rpx;
}

.stat-label {
  display: block;
  font-size: 12rpx;
  color: #999999;
  letter-spacing: 2rpx;
}
