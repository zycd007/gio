<view class="container">
  <!-- 分类视图 -->
  <view class="categories-view" wx:if="{{!showList}}">
    <view class="section-header">
      <text class="section-label">PORTFOLIO</text>
      <text class="section-title">案例分类</text>
    </view>
    <view class="cat-grid">
      <view class="cat-card" wx:for="{{categories}}" wx:key="id" bindtap="showCategory" data-id="{{item.id}}">
        <view class="cat-img">{{item.icon}}</view>
        <view class="cat-info">
          <text class="cat-name">{{item.name}}</text>
          <text class="cat-count">{{item.en}}</text>
          <view class="cat-count-bar">
            <view class="cat-count-fill" style="width: {{item.progress}}%"></view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 列表视图 -->
  <view class="list-view" wx:if="{{showList}}">
    <view class="list-header">
      <view>
        <text class="list-title">{{currentCategory.name}}</text>
        <text class="list-count">共 {{currentProjects.length}} 个项目</text>
      </view>
      <button class="back-btn" bindtap="backToCategories">← 返回</button>
    </view>
    <view class="project-list">
      <view class="project-card" wx:for="{{currentProjects}}" wx:key="id" bindtap="goToDetail"
        data-id="{{item.id}}"
        data-name="{{item.name}}"
        data-location="{{item.location}}"
        data-year="{{item.year}}"
        data-category="{{currentCategory.id}}">
        <view class="project-img">
          <image wx:if="{{item.images && item.images.length > 0}}" src="{{item.images[0]}}" mode="aspectFill" class="project-cover" binderror="onImageError" />
          <text wx:if="{{!item.images || item.images.length === 0}}" class="project-name-short">{{item.name}}</text>
        </view>
        <view class="project-info">
          <text class="project-name">{{item.name}}</text>
          <view class="project-meta">
            <text class="project-location">📍 {{item.location}}</text>
            <text class="project-year">{{item.year}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
